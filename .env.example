# Supabase Configuration
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# AI Configuration
VITE_OPENAI_API_KEY=your-openai-key
VITE_AI_MODEL=gpt-4o

# WhatsApp Business API
VITE_WHATSAPP_API_TOKEN=your-whatsapp-token
VITE_WHATSAPP_PHONE_NUMBER_ID=your-phone-id

# Payment Gateways
VITE_RAZORPAY_KEY=your-razorpay-key
VITE_STRIPE_PUBLIC_KEY=your-stripe-key

# Map Services
VITE_GOOGLE_MAPS_API_KEY=your-maps-key

# Environment
VITE_APP_ENV=development
VITE_APP_NAME=MUSLLY AI OS
VITE_APP_VERSION=1.0.0

# MUSLLY AI OS v2.1 Configuration
VITE_AI_SUN_VERSION=2.1
VITE_ENABLE_QUANTUM_MEMORY=true
VITE_SOVEREIGN_PROTOCOL=true

