# ──────────────────────────────────────────────────────────────
# Client-visible (bundled into the browser; never put secrets here)
# ──────────────────────────────────────────────────────────────
VITE_SUPABASE_URL=https://<project-ref>.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=eyJhbGciOi...           # anon/publishable JWT
VITE_SUPABASE_PROJECT_ID=<project-ref>

# ──────────────────────────────────────────────────────────────
# Server-only (TanStack server functions + server routes only)
# Lovable Cloud injects these automatically in production; keep
# this template in sync so local dev has the same surface.
# ──────────────────────────────────────────────────────────────
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_PUBLISHABLE_KEY=eyJhbGciOi...
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOi...               # NEVER expose to browser
SUPABASE_PROJECT_ID=<project-ref>

# Cron / webhook auth — see docs/security-operations.md
CRON_SECRET=                                           # rotated per-environment
WEBHOOK_SECRET=                                        # generic inbound HMAC

# AI gateway (Lovable AI). Auto-managed; rotate via tooling.
LOVABLE_API_KEY=

# Operational integrations (optional — feature flags off if blank)
SLACK_WEBHOOK_URL=
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM=
WHATSAPP_FROM=
N8N_WEBHOOK_URL=

# Email (Lovable Email + transactional)
RESEND_API_KEY=
EMAIL_FROM=
